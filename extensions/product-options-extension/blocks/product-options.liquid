<script>
  window.seProductOptions = {
    shop: "{{ shop.permanent_domain }}",
    product: {{ product | json }},
    collections: [
      {% for collection in product.collections %}
        {{ collection | json }}{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ],
    template: "{{ template.name }}"
  };

  (function() {
    function startInitialization() {
      if (window.__seProductOptionsStarted) return;
      if (!document.body) { setTimeout(startInitialization, 50); return; }
      if (!window.seProductOptions || !window.seProductOptions.product) { setTimeout(startInitialization, 100); return; }
      window.__seProductOptionsStarted = true;

      initProductOptions();
    }

    async function initProductOptions() {
      const findAndInject = () => {
        if (document.querySelector('.se-option-set')) return true;
        let root = document.querySelector('.se-product-options-container .se-options-content') ||
                   document.querySelector('.se-product-options-container') ||
                   document.getElementById('se-product-options-root');

        const atcSelectors = ['button[name="add"]', 'button.product-form__submit', '.product-form__buttons', '.add-to-cart', '#AddToCart', '[data-add-to-cart]', '.btn--add-to-cart'];
        let atcButton = null;
        for (const selector of atcSelectors) {
            atcButton = document.querySelector(selector);
            if (atcButton && atcButton.offsetWidth > 0) { break; }
        }

        if (!atcButton) {
          const form = document.querySelector('form[action^="/cart/add"]');
          if (form) atcButton = form;
        }

        if (!root && atcButton) {
          root = document.createElement('div');
          root.id = 'se-product-options-root';
          atcButton.parentNode.insertBefore(root, atcButton);
        }

        if (root) { fetchOptions(root); return true; }
        return false;
      };

      if (!findAndInject()) {
        const observer = new MutationObserver(() => { if (findAndInject()) observer.disconnect(); });
        observer.observe(document.body, { childList: true, subtree: true });
        setTimeout(() => {
            if (!document.querySelector('.se-option-set')) {
                const form = document.querySelector('form[action^="/cart/add"]');
                if (form) {
                    const root = document.createElement('div');
                    root.id = 'se-product-options-root-fallback';
                    form.prepend(root);
                    fetchOptions(root);
                }
            }
            observer.disconnect();
        }, 5000);
      }
    }

    function getActiveAddons() {
      const addons = [];
      const optionSets = window.__seOptionSets || [];
      
      optionSets.forEach(set => {
        const groups = typeof set.groups === 'string' ? JSON.parse(set.groups || '[]') : (set.groups || []);
        groups.forEach(group => {
          group.elements.forEach(el => {
            if (el.hidden) return;
            
            // 1. Element-level addons
            let shouldAddElementAddon = true;
            const input = document.getElementById('se-opt-' + el.id);

            if (['text', 'phone', 'email', 'number', 'textarea', 'date', 'color-picker'].includes(el.type)) {
              if (!input || !input.value || input.value.trim() === '') {
                shouldAddElementAddon = false;
              }
            } else if (el.type === 'switch') {
              if (!input || !input.checked) {
                shouldAddElementAddon = false;
              }
            }

            if (shouldAddElementAddon) {
              if (el.addonProduct && el.addonProduct.id) {
                  const numericId = el.addonProduct.id.toString().split('/').pop();
                  const gid = el.addonProduct.id.toString().includes('gid://') ? el.addonProduct.id : 'gid://shopify/ProductVariant/' + numericId;
                  const price = el.price || el.addonProduct.price || 0;
                  addons.push({ id: numericId, gid: gid, price: price, quantity: 1, label: el.label || 'Add-on' });
              } else if (el.price > 0 && !['select', 'radio', 'checkbox', 'checkbox-group', 'button', 'color-swatch', 'image-swatch'].includes(el.type)) {
                  addons.push({ id: null, gid: null, price: el.price, quantity: 1, label: el.label || 'Price Increase' });
              }
            }

            // 2. Option-level addons (Select, Radio, Checkbox, Button, Color/Image Swatches)
            if (['select', 'radio', 'checkbox', 'checkbox-group', 'button', 'color-swatch', 'image-swatch'].includes(el.type)) {
              const elId = 'se-opt-' + (el.id || '');
              let selectedValues = [];

              if (el.type === 'select') {
                const select = document.getElementById(elId);
                if (select) {
                  selectedValues = Array.from(select.selectedOptions).map(o => o.value).filter(Boolean);
                }
              } else if (el.type === 'radio' || el.type === 'color-swatch' || el.type === 'image-swatch') {
                const propertyName = el.name || el.label;
                const checked = document.querySelector('input[name="properties[' + propertyName + ']"]:checked');
                if (checked) selectedValues.push(checked.value);
              } else if (el.type === 'checkbox' || el.type === 'checkbox-group') {
                const checks = document.querySelectorAll('.se-check-' + elId + ':checked');
                checks.forEach(c => selectedValues.push(c.value));
              } else if (el.type === 'button') {
                const hiddenInput = document.getElementById(elId + '-btn');
                if (hiddenInput && hiddenInput.value) {
                  selectedValues.push(hiddenInput.value);
                }
              }

              selectedValues.forEach(val => {
                const opt = (el.optionValues || []).find(o => o.value === val);
                if (opt) {
                  const price = parseFloat(opt.price) || 0;
                  if (opt.addonProduct && opt.addonProduct.id) {
                    const numericId = opt.addonProduct.id.toString().split('/').pop();
                    const gid = opt.addonProduct.id.toString().includes('gid://') ? opt.addonProduct.id : 'gid://shopify/ProductVariant/' + numericId;
                    addons.push({ id: numericId, gid: gid, price: price || opt.addonProduct.price || 0, quantity: 1, label: opt.value });
                  } else if (price > 0) {
                    addons.push({ id: null, gid: null, price: price, quantity: 1, label: opt.value });
                  }
                }
              });
            }
          });
        });
      });
      return addons;
    }

    function getWidgetProperties() {
      const props = {};
      const root = document.querySelector('.se-product-options-container') || document.getElementById('se-product-options-root');
      if (!root) return props;

      const inputs = root.querySelectorAll('[name^="properties["]');
      inputs.forEach(input => {
        const parent = input.closest('.se-option-element');
        if (parent && parent.style.display === 'none') return;
        
        if ((input.type === 'radio' || input.type === 'checkbox') && !input.checked) return;
        
        // Skip empty inputs
        if (!['radio', 'checkbox'].includes(input.type) && (!input.value || input.value.trim() === '')) return;
        
        const match = input.name.match(/properties\[(.*?)\]/);
        if (match && match[1]) {
          props[match[1]] = input.value;
        }
      });
      return props;
    }

    function applyConditionalLogic(container) {
      if (!container) return;
      const allElements = container.querySelectorAll('.se-option-element');
      if (allElements.length === 0) return;
      const currentValues = {};

      const getVariantId = () => {
        return new URLSearchParams(window.location.search).get('variant') || 
               document.querySelector('form[action^="/cart/add"] input[name="id"]')?.value;
      };

      const variantId = getVariantId();

      // 1. Gather values
      allElements.forEach(elWrapper => {
        const config = elWrapper.__seConfig;
        if (!config) return;
        const inputs = Array.from(elWrapper.querySelectorAll('input, select, textarea'));
        let val = undefined;
        if (config.type === 'checkbox' || config.type === 'checkbox-group') {
           val = inputs.filter(i => i.checked).map(i => i.value);
        } else if (config.type === 'radio' || config.type === 'color-swatch' || config.type === 'image-swatch') {
           const checked = inputs.find(i => i.checked);
           val = checked ? checked.value : "";
        } else if (config.type === 'button') {
           const activeBtn = elWrapper.querySelector('.se-btn-option--active');
           val = activeBtn ? activeBtn.dataset.value : "";
        } else if (inputs.length > 0) {
           val = inputs[0].value;
        }
        if (val !== undefined) {
          currentValues[config.id.toString()] = val;
        }
      });

      // 2. Evaluate
      allElements.forEach(elWrapper => {
        const el = elWrapper.__seConfig;
        
        if (!el || !el.logicEnabled || !el.conditions) {
           return;
        }

        const validConditions = el.conditions.filter(cond => cond.field && cond.field.trim() !== "");
        if (validConditions.length === 0) {
          elWrapper.style.display = "";
          return;
        }

        const logicType = el.logicType || "Show";
        const logicOperator = el.logicOperator || "All";

        const results = validConditions.map(cond => {
          const fieldKey = cond.field.toString();
          let currentVal = fieldKey === 'shopify_variant' ? variantId : currentValues[fieldKey];
          
          if (currentVal === undefined || currentVal === null) currentVal = "";
          
          const target = String(cond.value || "").toLowerCase();
          const op = cond.operator;
          const isArray = Array.isArray(currentVal);
          const valStr = isArray ? currentVal.map(v => String(v).toLowerCase()) : String(currentVal).toLowerCase();

          switch(op) {
            case 'EQUALS': 
              return isArray ? valStr.includes(target) : valStr == target;
            case 'NOT_EQUALS': 
              return isArray ? !valStr.includes(target) : valStr != target;
            case 'GREATER_THAN': 
              return Number(currentVal) > Number(target);
            case 'LESS_THAN': 
              return Number(currentVal) < Number(target);
            case 'STARTS_WITH': 
              return !isArray && valStr.startsWith(target);
            case 'ENDS_WITH': 
              return !isArray && valStr.endsWith(target);
            case 'CONTAINS': 
              return isArray ? valStr.includes(target) : valStr.includes(target);
            case 'NOT_CONTAINS': 
              return isArray ? !valStr.includes(target) : !valStr.includes(target);
            default: return false;
          }
        });

        let isMet = logicOperator === 'All' ? results.every(r => r) : results.some(r => r);
        let shouldShow = logicType === 'Show' ? isMet : !isMet;
        elWrapper.style.display = shouldShow ? "" : "none";
      });
    }

    function applyGlobalSettings(settings) {
      if (!settings) return;
      const id = "se-storefront-settings-style";
      let styleEl = document.getElementById(id);
      if (!styleEl) {
        styleEl = document.createElement("style");
        styleEl.id = id;
        document.head.appendChild(styleEl);
      }
      
      const s = settings;
      const c = s.colors || {};
      const b = s.borders || {};
      const t = s.typography || {};
      const a = s.additional || {};
      
      // Load Google Fonts if they are set
      const fontList = [];
      if (t.labelText && t.labelText.font) fontList.push(t.labelText.font);
      if (t.mainText && t.mainText.font) fontList.push(t.mainText.font);
      if (fontList.length > 0) {
        const fontId = "se-storefront-google-fonts";
        let fontLink = document.getElementById(fontId);
        if (!fontLink) {
          fontLink = document.createElement("link");
          fontLink.id = fontId;
          fontLink.rel = "stylesheet";
          document.head.appendChild(fontLink);
        }
        fontLink.href = 'https://fonts.googleapis.com/css2?family=' + Array.from(new Set(fontList)).map(f => f.replace(/ /g, '+')).join('&family=') + '&display=swap';
      }

      styleEl.innerHTML = `
        #se-product-options-root,
        .se-product-options-container {
          font-family: '${t.mainText?.font || "Inter"}', sans-serif !important;
          background-color: ${c.general?.appBackground || "#ffffff"} !important;
        }
        #se-product-options-root .se-option-element label,
        #se-product-options-root .se-label-price,
        #se-product-options-root .se-switch-label-text,
        .se-product-options-container .se-option-element label,
        .se-product-options-container .se-label-price,
        .se-product-options-container .se-switch-label-text {
          color: ${c.general?.labelText || "#000000"} !important;
          font-size: ${t.labelText?.baseSize || 13}px !important;
          font-family: '${t.labelText?.font || "Inter"}', sans-serif !important;
        }
        #se-product-options-root .se-option-element label .se-required,
        .se-product-options-container .se-option-element label .se-required {
          color: ${c.general?.requiredCharacter || "#ff0000"} !important;
        }
        #se-product-options-root .se-input,
        .se-product-options-container .se-input {
          color: ${c.singleInput?.inputText || "#000000"} !important;
          background-color: ${c.singleInput?.inputBackground || "#ffffff"} !important;
          border: ${b.input?.borderSize ?? 1}px solid ${c.singleInput?.inputBorder || "#121212"} !important;
          border-radius: ${b.input?.borderRadius ?? 8}px !important;
          font-size: ${t.mainText?.baseSize || 13}px !important;
          font-family: '${t.mainText?.font || "Inter"}', sans-serif !important;
        }
        #se-product-options-root .se-input:focus,
        .se-product-options-container .se-input:focus {
          border-color: ${c.singleInput?.inputBorder || "#121212"} !important;
          box-shadow: 0 0 0 1px ${c.singleInput?.inputBorder || "#121212"} !important;
        }
        #se-product-options-root .se-file-upload-box,
        .se-product-options-container .se-file-upload-box {
          border: ${b.input?.borderSize ?? 2}px dashed ${c.singleInput?.inputBorder || "#121212"} !important;
          border-radius: ${b.input?.borderRadius ?? 8}px !important;
        }
        #se-product-options-root .se-color-picker-trigger,
        #se-product-options-root .se-cp-hex-input,
        .se-product-options-container .se-color-picker-trigger,
        .se-product-options-container .se-cp-hex-input {
          border: ${b.input?.borderSize ?? 1}px solid ${c.singleInput?.inputBorder || "#121212"} !important;
          border-radius: ${b.input?.borderRadius ?? 8}px !important;
        }
        #se-product-options-root select.se-input,
        .se-product-options-container select.se-input {
          color: ${c.choiceList?.dropdownText || "#121212"} !important;
          background-color: ${c.choiceList?.dropdownBackground || "#ffffff"} !important;
          border: ${b.dropdown?.borderSize ?? 1}px solid ${c.choiceList?.dropdownBorder || "#121212"} !important;
          border-radius: ${b.dropdown?.borderRadius ?? 8}px !important;
          font-family: '${t.mainText?.font || "Inter"}', sans-serif !important;
        }
        #se-product-options-root select.se-input[multiple] option:checked,
        .se-product-options-container select.se-input[multiple] option:checked {
          background-color: ${c.choiceList?.dropdownBackground || "#ffffff"} !important;
          color: ${c.choiceList?.dropdownText || "#121212"} !important;
          box-shadow: 0 0 0 1px ${c.choiceList?.dropdownBorder || "#121212"} !important;
        }
        #se-product-options-root .se-slider,
        .se-product-options-container .se-slider {
          background-color: ${c.singleInput?.switchBackground || "#dddddd"} !important;
          border-color: ${c.singleInput?.switchBackground || "#dddddd"} !important;
          border-radius: 24px !important;
        }
        #se-product-options-root .se-switch input:checked + .se-slider,
        .se-product-options-container .se-switch input:checked + .se-slider {
          background-color: ${c.singleInput?.switchActiveBackground || "#121212"} !important;
          border-color: ${c.singleInput?.switchActiveBackground || "#121212"} !important;
        }
        #se-product-options-root .se-radio-custom,
        .se-product-options-container .se-radio-custom {
          border-width: ${b.input?.borderSize ?? 1}px !important;
          border-style: solid !important;
          border-color: ${c.singleInput?.inputBorder || "#121212"} !important;
        }
        #se-product-options-root .se-radio-item:hover .se-radio-custom,
        .se-product-options-container .se-radio-item:hover .se-radio-custom {
          border-color: ${c.singleInput?.inputBorder || "#121212"} !important;
        }
        #se-product-options-root .se-radio-label,
        #se-product-options-root .se-radio-option-row,
        .se-product-options-container .se-radio-label,
        .se-product-options-container .se-radio-option-row {
          color: ${c.choiceList?.checkboxRadioText || "#000000"} !important;
          font-size: ${t.mainText?.baseSize || 13}px !important;
          font-family: '${t.mainText?.font || "Inter"}', sans-serif !important;
        }
        #se-product-options-root .se-radio-item input[type="radio"]:checked + .se-radio-custom-radio,
        .se-product-options-container .se-radio-item input[type="radio"]:checked + .se-radio-custom-radio {
          border-width: ${b.input?.borderSize ?? 1}px !important;
          border-color: ${c.choiceList?.checkboxRadioActive || "#121212"} !important;
          background-color: ${c.general?.appBackground || "#ffffff"} !important;
        }
        #se-product-options-root .se-radio-item input[type="radio"]:checked + .se-radio-custom-radio::after,
        .se-product-options-container .se-radio-item input[type="radio"]:checked + .se-radio-custom-radio::after {
          background-color: ${c.choiceList?.checkboxRadioActive || "#121212"} !important;
        }
        #se-product-options-root .se-radio-item input[type="checkbox"]:checked + .se-radio-custom-checkbox,
        .se-product-options-container .se-radio-item input[type="checkbox"]:checked + .se-radio-custom-checkbox {
          border-width: ${b.input?.borderSize ?? 1}px !important;
          border-color: ${c.choiceList?.checkboxRadioActive || "#121212"} !important;
          background-color: ${c.choiceList?.checkboxRadioActive || "#121212"} !important;
        }
        #se-product-options-root .se-btn-option,
        .se-product-options-container .se-btn-option {
          color: ${c.swatch?.buttonText || "#000000"} !important;
          background: ${c.swatch?.buttonBackground || "#ffffff"} !important;
          border-color: ${c.swatch?.swatchBorder || "#dddddd"} !important;
          border-width: ${b.swatch?.borderSize ?? 1}px !important;
          border-radius: ${b.swatch?.borderRadius ?? 6}px !important;
          font-size: ${t.mainText?.baseSize || 13}px !important;
          font-family: '${t.mainText?.font || "Inter"}', sans-serif !important;
        }
        #se-product-options-root .se-btn-option:hover,
        .se-product-options-container .se-btn-option:hover {
          color: ${c.swatch?.buttonTextHover || "#121212"} !important;
          background: ${c.swatch?.buttonBackgroundHover || "#ffffff"} !important;
          border-color: ${c.swatch?.swatchBorderHover || "#dddddd"} !important;
        }
        #se-product-options-root .se-btn-option--active,
        .se-product-options-container .se-btn-option--active {
          color: ${c.swatch?.buttonTextActive || "#ffffff"} !important;
          background: ${c.swatch?.buttonBackgroundActive || "#121212"} !important;
          border-color: ${c.swatch?.swatchBorderActive || "#121212"} !important;
        }
        #se-product-options-root .se-swatch,
        #se-product-options-root .se-radio-item--swatch .se-swatch,
        .se-product-options-container .se-swatch,
        .se-product-options-container .se-radio-item--swatch .se-swatch {
          border-color: ${c.swatch?.swatchBorder || "#dddddd"} !important;
          border-width: ${b.swatch?.borderSize ?? 1}px !important;
          border-radius: ${b.swatch?.borderRadius ?? 6}px !important;
        }
        #se-product-options-root .se-radio-item--swatch:hover .se-swatch,
        .se-product-options-container .se-radio-item--swatch:hover .se-swatch {
          border-color: ${c.swatch?.swatchBorderHover || "#aaa"} !important;
        }
        #se-product-options-root .se-radio-item--swatch input:checked ~ .se-radio-label .se-swatch,
        .se-product-options-container .se-radio-item--swatch input:checked ~ .se-radio-label .se-swatch {
          border-color: transparent !important;
          outline: 2px solid ${c.swatch?.swatchBorderActive || "#121212"} !important;
          outline-offset: 3px;
        }
        ${a.customCss || ""}
      `;
    }


    async function fetchOptions(root) {
      if (root.dataset.loading === "true") return;
      root.dataset.loading = "true";
      try {
        const response = await fetch('/apps/se-product-options/api/options', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            shop: window.seProductOptions.shop,
            product: window.seProductOptions.product,
            collections: window.seProductOptions.collections || []
          })
        });
        const contentType = response.headers.get("content-type");
        if (!contentType || !contentType.includes("application/json")) return;
        const data = await response.json();
        if (data.settings) {
          applyGlobalSettings(data.settings);
        }
        if (data.optionSets && data.optionSets.length > 0) {
          window.__seOptionSets = data.optionSets;
          renderOptionSets(root, data.optionSets);
        }
      } catch (error) { }
      finally { delete root.dataset.loading; }
    }

    function renderOptionSets(container, optionSets) {
      container.innerHTML = '';
      const addonVariants = [];
      optionSets.forEach(set => {
        try {
          const setElement = document.createElement('div');
          setElement.className = 'se-option-set';
          const groups = typeof set.groups === 'string' ? JSON.parse(set.groups || '[]') : (set.groups || []);
          groups.forEach(group => {
            if (group.hidden) return;
            const groupElement = document.createElement('div');
            groupElement.className = 'se-option-group';
            group.elements.forEach(el => {
              if (el.hidden) return;
              try {
                const elContainer = document.createElement('div');
                const colWidth = el.columnWidth || '100%';
                const colClass = 'se-col-' + colWidth.replace('%', '');
                elContainer.className = ('se-option-element ' + (el.htmlClass || '') + ' ' + colClass).replace(/\s+/g, ' ').trim();
                elContainer.__seConfig = el;
                const elId = 'se-opt-' + (el.id || Math.random().toString(36).substr(2, 9));
                {% comment %} console.log("[SE] Rendering element:", el.type, el.label); {% endcomment %}

                if (el.addonProduct && el.addonProduct.id) {
                    const numericId = el.addonProduct.id.toString().split('/').pop();
                    const gid = el.addonProduct.id.toString().includes('gid://') ? el.addonProduct.id : 'gid://shopify/ProductVariant/' + numericId;
                    const price = el.price || el.addonProduct.price || 0;
                    addonVariants.push({ id: numericId, gid: gid, price: price, quantity: 1, label: el.label || 'Add-on' });
                } else if (el.price > 0) {
                    addonVariants.push({ id: null, gid: null, price: el.price, quantity: 1, label: el.label || 'Price Increase' });
                }

                let tooltipHtml = '';
                if (el.helpText && el.helpTextPosition === 'tooltip') {
                  tooltipHtml = '<span class="se-tooltip-container"><i class="se-tooltip-icon">i</i><span class="se-tooltip-text">' + el.helpText + '</span></span>';
                }
                const priceHtml = el.price > 0 ? ' <span class="se-label-price">(+ $' + parseFloat(el.price).toFixed(2) + ')</span>' : '<span id="' + elId + '-price-label" class="se-label-price"></span>';
                const labelHtml = (el.hiddenLabel || el.type === 'heading' || el.type === 'divider' || el.type === 'spacing' || el.type === 'paragraph' || el.type === 'html') ? '' : '<label for="' + elId + '">' + el.label + priceHtml + (el.required ? ' <span class="se-required">*</span>' : '') + tooltipHtml + '</label>';
                const helpTextHtml = el.helpText ? '<div class="se-help-text">' + el.helpText + '</div>' : '';
                const charCounterHtml = (el.showCharacterCounter && el.maxCharacter) ? '<div id="' + elId + '-counter" class="se-char-counter">0 / ' + el.maxCharacter + '</div>' : '';
                let html = el.helpTextPosition === 'above' ? helpTextHtml : '';
                html += labelHtml;
                const textTransformClass = el.textTransform ? 'se-text-' + el.textTransform : '';
                const propertyName = el.name || el.label;

                if (el.type === 'date') {
                  const iconClass = el.dateFormat === 'time' ? 'clock' : 'calendar';
                  const propertyName = el.name || el.label;
                  
                  html += '<div class="se-datetime-container">';
                  if (el.dateMode === 'range') {
                    html += `
                      <div class="se-datetime-range">
                        <div class="se-datetime-input-wrapper">
                          <input id="${elId}-start" class="se-input se-datetime-input" type="text" name="properties[${propertyName} (Start)]" placeholder="${el.placeholderStart || ''}" ${el.required ? 'required' : ''} readonly>
                          <span class="se-datetime-icon ${iconClass}"></span>
                        </div>
                        <span class="se-range-separator">to</span>
                        <div class="se-datetime-input-wrapper">
                          <input id="${elId}-end" class="se-input se-datetime-input" type="text" name="properties[${propertyName} (End)]" placeholder="${el.placeholderEnd || ''}" ${el.required ? 'required' : ''} readonly>
                          <span class="se-datetime-icon ${iconClass}"></span>
                        </div>
                      </div>
                    `;
                  } else {
                    html += `
