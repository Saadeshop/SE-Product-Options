                      tooltipHtml = '<div class="se-btn-swatch-tooltip"><div class="se-btn-swatch-tooltip-title">' + opt.value + priceSuffix + '</div><div class="se-btn-swatch-tooltip-preview" style="' + previewStyle + '"></div></div>';
