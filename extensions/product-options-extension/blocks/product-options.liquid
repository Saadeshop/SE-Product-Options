                  html += '<select id="' + elId + '" class="' + ('se-input ' + textTransformClass).trim() + '" ' + selectName + ' ' + (el.required ? 'required' : '') + ' ' + multipleAttr + '>';
                  
                  const hasDefault = (el.optionValues || []).some(o => o.isDefault);
                  const placeholderText = el.placeholder || "-- Please select --";
                  html += '<option value="" ' + (hasDefault ? '' : 'selected') + ' disabled>' + placeholderText + '</option>';

