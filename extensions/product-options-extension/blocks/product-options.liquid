                  }

                  setTimeout(() => {
                    const select = document.getElementById(elId);
                    const hidden = document.getElementById(elId + '-hidden');
                    const priceLabel = document.getElementById(elId + '-price-label');

                    if (select) {
                      const updateAll = () => {
                        const selectedOptions = Array.from(select.selectedOptions);
                        
                        // 1. Update Hidden Input (if multiple)
                        if (hidden) {
                          const selectedValues = selectedOptions.map(o => o.value).filter(Boolean);
                          hidden.value = selectedValues.join(', ');
                        }

                        // 2. Update Label Price
                        let totalExtra = 0;
                        selectedOptions.forEach(optNode => {
                          const val = optNode.value;
                          if (!val) return;
                          const opt = (el.optionValues || []).find(o => o.value === val);
                          if (opt) totalExtra += parseFloat(opt.price) || 0;
