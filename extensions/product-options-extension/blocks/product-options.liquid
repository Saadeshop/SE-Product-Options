                      </div>
                    `;
                  }
                  html += '</div>';
                } else if (['text', 'phone', 'email', 'number', 'textarea'].includes(el.type)) {
                  const maxLengthAttr = el.maxCharacter ? ' maxlength="' + el.maxCharacter + '"' : '';
                  const propertyName = el.name || el.label;
                  if (el.type === 'textarea') {
                    html += '<textarea id="' + elId + '" class="' + ('se-input ' + textTransformClass).trim() + '" name="properties[' + propertyName + ']" rows="4" placeholder="' + (el.placeholder || '') + '" ' + (el.required ? 'required' : '') + maxLengthAttr + '>' + (el.defaultValue || '') + '</textarea>';
                  } else {
                    let inputType = el.type === 'phone' ? 'tel' : el.type;
                    html += '<input id="' + elId + '" class="' + ('se-input ' + textTransformClass).trim() + '" type="' + inputType + '" name="properties[' + propertyName + ']" value="' + (el.defaultValue || '') + '" placeholder="' + (el.placeholder || '') + '" ' + (el.required ? 'required' : '') + maxLengthAttr + '>';
                  }
                  const showBottomHelp = (!el.helpTextPosition || el.helpTextPosition === 'below') && el.helpText;
                  if (showBottomHelp || charCounterHtml) {
                    html += '<div class="se-bottom-row">' + (showBottomHelp ? helpTextHtml : '') + charCounterHtml + '</div>';
                  }
                } else if (el.type === 'color-picker') {
                  const propertyName = el.name || el.label;
                  const defaultColor = el.defaultValue || '#000000';
                  const PRESETS = ['#000000','#434343','#666666','#999999','#b7b7b7','#cccccc','#d9d9d9','#ffffff','#e06666','#f6b26b','#ffd966','#93c47d','#76a5af','#6fa8dc','#8e7cc3','#c27ba0','#cc0000','#e69138','#f1c232','#6aa84f','#45818e','#3d85c6','#674ea7','#a64d79','#990000','#b45f06','#bf9000','#38761d','#134f5c','#0b5394','#351c75','#741b47'];
                  
                  html += `
                    <div class="se-color-picker-container" id="${elId}-container">
                      <input type="hidden" id="${elId}" name="properties[${propertyName}]" value="${defaultColor}" ${el.required ? 'required' : ''}>
                      <div class="se-color-picker-trigger" id="${elId}-trigger">
                        <div class="se-color-picker-swatch"><div class="se-color-picker-swatch-inner" id="${elId}-swatch" style="background-color:${defaultColor}"></div></div>
                        <span class="se-color-picker-hex-label" id="${elId}-hex">${defaultColor}</span>
                        <svg class="se-color-picker-chevron" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
                      </div>
                      <div id="${elId}-overlay" class="se-cp-overlay" style="display:none"></div>
                      <div class="se-color-picker-dropdown" id="${elId}-dropdown">
                        <div class="se-cp-saturation" id="${elId}-sat" style="background-color:hsl(0,100%,50%)">
                          <div class="se-cp-saturation-white"></div>
                          <div class="se-cp-saturation-black"></div>
                          <div class="se-cp-saturation-pointer" id="${elId}-sat-ptr"></div>
                        </div>
                        <div class="se-cp-hue-wrap" id="${elId}-hue">
                          <div class="se-cp-hue-thumb" id="${elId}-hue-thumb"></div>
                        </div>
                        <div class="se-cp-presets">${PRESETS.map(c => '<div class="se-cp-preset" data-color="'+c+'" style="background-color:'+c+'"></div>').join('')}</div>
                        <div class="se-cp-hex-row">
                          <span>Hex</span>
                          <input type="text" class="se-cp-hex-input" id="${elId}-hex-input" value="${defaultColor}" maxlength="7">
                        </div>
                      </div>
                    </div>
                  `;
                  
                  const showBottomHelp = (!el.helpTextPosition || el.helpTextPosition === 'below') && el.helpText;
                  if (showBottomHelp) {
                    html += '<div class="se-bottom-row">' + helpTextHtml + '</div>';
                  }
                  
                  setTimeout(() => {
                    const container = document.getElementById(elId + '-container');
                    if (!container || container.dataset.cpBound) return;
                    container.dataset.cpBound = 'true';
                    
                    const trigger = document.getElementById(elId + '-trigger');
                    const dropdown = document.getElementById(elId + '-dropdown');
                    const overlay = document.getElementById(elId + '-overlay');
                    const satEl = document.getElementById(elId + '-sat');
                    const satPtr = document.getElementById(elId + '-sat-ptr');
                    const hueBar = document.getElementById(elId + '-hue');
                    const hueThumb = document.getElementById(elId + '-hue-thumb');
                    const hexInput = document.getElementById(elId + '-hex-input');
                    const hexLabel = document.getElementById(elId + '-hex');
                    const swatchInner = document.getElementById(elId + '-swatch');
                    const hiddenInput = document.getElementById(elId);
                    
                    let hue = 0, sat = 100, bri = 0;
                    
                    const parseHex = (hex) => {
                      const r = parseInt(hex.slice(1,3),16)/255, g = parseInt(hex.slice(3,5),16)/255, b = parseInt(hex.slice(5,7),16)/255;
                      const max = Math.max(r,g,b), min = Math.min(r,g,b), d = max - min;
                      let h = 0;
                      if (d !== 0) { if (max === r) h = ((g-b)/d + (g<b?6:0))/6; else if (max === g) h = ((b-r)/d+2)/6; else h = ((r-g)/d+4)/6; }
                      return { h: h*360, s: max === 0 ? 0 : (d/max)*100, v: max*100 };
                    };
                    
                    const hsb = parseHex(defaultColor);
                    hue = hsb.h; sat = hsb.s; bri = hsb.v;
                    
                    const hsbToHex = (h, s, v) => {
                      s /= 100; v /= 100;
                      const c = v*s, x = c*(1-Math.abs(((h/60)%2)-1)), m = v-c;
                      let r=0,g=0,b=0;
                      if(h<60){r=c;g=x;}else if(h<120){r=x;g=c;}else if(h<180){g=c;b=x;}else if(h<240){g=x;b=c;}else if(h<300){r=x;b=c;}else{r=c;b=x;}
                      return '#'+[r+m,g+m,b+m].map(v=>Math.round(v*255).toString(16).padStart(2,'0')).join('');
                    };
                    
                    const updateUI = () => {
                      const hex = hsbToHex(hue, sat, bri);
                      if (hiddenInput) hiddenInput.value = hex;
                      if (swatchInner) swatchInner.style.backgroundColor = hex;
                      if (hexLabel) hexLabel.textContent = hex;
                      if (hexInput && document.activeElement !== hexInput) hexInput.value = hex;
                      if (satEl) satEl.style.backgroundColor = 'hsl(' + hue + ', 100%, 50%)';
                      if (satPtr) { satPtr.style.left = sat + '%'; satPtr.style.top = (100 - bri) + '%'; }
                      if (hueThumb) hueThumb.style.left = (hue / 360 * 100) + '%';
                      container.querySelectorAll('.se-cp-preset').forEach(function(p) { p.classList.toggle('se-cp-active', p.dataset.color === hex); });
                    };
                    
                    // Toggle dropdown
                    trigger.addEventListener('click', function() {
                      const isOpen = dropdown.classList.contains('se-cp-visible');
