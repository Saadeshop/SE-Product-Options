                        if (priceLabel) {
                          if (totalExtra > 0) {
                            priceLabel.textContent = ' (+ $' + totalExtra.toFixed(2) + ')';
                          } else {
                            priceLabel.textContent = '';
                          }
                        }
                      };

                      select.addEventListener('change', updateAll);
                      updateAll(); // Initial sync
                    }
