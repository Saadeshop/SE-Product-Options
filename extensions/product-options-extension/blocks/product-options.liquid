                    let swatchHtml = '';
                    if (el.swatchStyle === 'color') {
                      if (opt.swatchMode === 'two') {
                        swatchHtml = '<span class="se-swatch se-swatch-two" style="--se-swatch-c1: ' + (opt.swatchValue || '#000000') + '; --se-swatch-c2: ' + (opt.swatchValue2 || '#ffffff') + ';"></span>';
                      } else {
                        swatchHtml = '<span class="se-swatch se-swatch-one" style="--se-swatch-c1: ' + (opt.swatchValue || '#000000') + ';"></span>';
                      }
                    } else if (el.swatchStyle === 'image' && opt.swatchImage) {
                      swatchHtml = '<span class="se-swatch se-swatch-image" style=\'--se-swatch-img: url("' + opt.swatchImage + '");\'></span>';
                    }
                    
                    html += swatchHtml + '      <span>' + opt.value + priceSuffix + '</span>';
                    if (opt.helpText && el.helpTextPosition === 'tooltip') {
                      html += '<span class="se-tooltip-container"><i class="se-tooltip-icon">i</i><span class="se-tooltip-text">' + opt.helpText + '</span></span>';
                    }
                    html += '    </span>';
                    if (opt.helpText && (!el.helpTextPosition || el.helpTextPosition === 'below')) {
                      html += '<span class="se-radio-option-help se-help-below">' + opt.helpText + '</span>';
                    }
                    html += '  </span>';
                    html += '</label>';
                  });
                  html += '</div>';

                  setTimeout(() => {
                    const inputs = document.querySelectorAll('.se-check-' + elId);
                    const hidden = document.getElementById(elId + '-hidden');
                    const priceLabel = document.getElementById(elId + '-price-label');

                    const updateAll = (e) => {
                      const checkedInputs = Array.from(inputs).filter(r => r.checked);
                      
                      // Max Selections Enforcement
                      if (e && e.target && e.target.checked) {
                        if (el.maxSelections && checkedInputs.length > el.maxSelections) {
                          e.target.checked = false;
                          return;
                        }
                      }

                      let totalExtra = 0;
                      let selectedValues = [];

                      inputs.forEach(r => {
                        if (r.checked) {
                          const val = r.value;
                          const opt = (el.optionValues || []).find(o => o.value === val);
                          if (opt) totalExtra += parseFloat(opt.price) || 0;
                          selectedValues.push(val);
                        }
                      });

                      if (priceLabel) {
                        priceLabel.textContent = totalExtra > 0 ? ' (+ $' + totalExtra.toFixed(2) + ')' : '';
                      }

                      if (hidden) {
                        hidden.value = selectedValues.join(', ');
                        const selectedCount = selectedValues.length;
                        const min = el.minSelections || 1;
                        hidden.dataset.valid = selectedCount >= min;
                      }
                    };

                    inputs.forEach(r => r.addEventListener('change', updateAll));

                    // Swatch deselect/not-deselect logic (closure-based tracking, identical to button behavior)
                    if (el.type === 'color-swatch' || el.type === 'image-swatch') {
                      let currentActiveValue = '';
                      const activeInput = Array.from(inputs).find(r => r.checked);
                      if (activeInput) {
                        currentActiveValue = activeInput.value;
                      }

                      inputs.forEach(r => {
                        r.addEventListener('click', function(e) {
                          if (this.value === currentActiveValue) {
                            if (el.notAllowDeselect) {
                              this.checked = true;
                            } else {
                              this.checked = false;
                              currentActiveValue = '';
                              updateAll();
                            }
                          } else {
                            currentActiveValue = this.value;
                          }
                        });
                      });
                    }

                    updateAll();
                  }, 0);

                  if (isMultiple) {
                    let constraintNote = '';
                    if (el.minSelections && el.maxSelections) {
                      constraintNote = 'Choose ' + el.minSelections + ' - ' + el.maxSelections + ' options';
                    } else if (el.minSelections) {
                      constraintNote = 'Choose minimum ' + el.minSelections + ' option' + (el.minSelections > 1 ? 's' : '');
                    } else if (el.maxSelections) {
                      constraintNote = 'Choose maximum ' + el.maxSelections + ' option' + (el.maxSelections > 1 ? 's' : '');
                    }
                    if (constraintNote) {
                      html += '<div class="se-constraint-note">' + constraintNote + '</div>';
                    }
                  }

                  if (el.helpTextPosition === 'below' || !el.helpTextPosition) html += helpTextHtml;
                } else if (el.type === 'file') {
                  const allowedAttr = el.allowedExtensions?.length > 0 ? ' accept="' + el.allowedExtensions.map(e => '.' + e).join(',') + '"' : '';
                  html += `
                    <div class="se-file-upload-container">
                      <div class="se-file-upload-box">
                        <svg class="se-file-upload-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path>
                        </svg>
                        <div class="se-file-upload-info">Upload file</div>
                        ${el.allowedExtensions?.length > 0 ? '<div class="se-file-upload-hint">Accepted: ' + el.allowedExtensions.join(', ') + '</div>' : ''}
                        <input id="${elId}" class="se-file-upload-input" type="file" name="properties[${propertyName}]" ${el.required ? 'required' : ''} ${allowedAttr}>
                      </div>
                      <div id="${elId}-filename" class="se-file-upload-name" style="display: none;"></div>
                      ${(el.helpTextPosition === 'below' || !el.helpTextPosition) ? helpTextHtml : ''}
                    </div>
                  `;
                  
                  setTimeout(() => {
                    const fileInput = document.getElementById(elId);
                    const nameDiv = document.getElementById(elId + '-filename');
                    if (fileInput && nameDiv) {
                      fileInput.addEventListener('change', function() {
                        if (this.files && this.files[0]) {
                          nameDiv.textContent = this.files[0].name;
                          nameDiv.style.display = 'flex';
                        } else {
                          nameDiv.style.display = 'none';
                        }
                      });
                    }
                  }, 0);
                } else if (el.type === 'heading') {
                  const tag = (el.headingStyle || 'H2').toLowerCase();
                  const color = el.headingColor || '#1a1a1a';
                  const content = el.content || el.label || 'Heading';
                  html = '<' + tag + ' class="se-heading se-heading-' + tag + '" style="--se-heading-color: ' + color + ';">' + content + '</' + tag + '>';
                } else if (el.type === 'divider') {
                  const thickness = el.dividerThickness || 1;
                  const style = el.dividerStyle || 'solid';
                  const color = el.dividerColor || '#e1e3e5';
                  html = '<div class="se-divider" style="--se-divider-style: ' + style + '; --se-divider-thickness: ' + thickness + 'px; --se-divider-color: ' + color + ';"></div>';
                } else if (el.type === 'spacing') {
                  const height = el.spacingHeight || 20;
                  html = '<div class="se-spacing" style="height: ' + height + 'px;"></div>';
                } else if (el.type === 'paragraph') {
                  const content = el.content || '';
                  html = '<div class="se-paragraph">' + content + '</div>';
                } else if (el.type === 'html') {
                  const content = el.htmlContent || '';
                  html = '<div class="se-html">' + content + '</div>';
                }

                elContainer.innerHTML = html;
                groupElement.appendChild(elContainer);

                setTimeout(() => {
                  const input = document.getElementById(elId);

                  if (!input || input.dataset.validationBound) return;

                  input.dataset.validationBound = 'true';

                  // Multi-select toggle helper
                  if (el.type === 'select' && el.allowMultiple) {
                    input.addEventListener('mousedown', function(e) {
                      e.preventDefault();
                      const option = e.target;
                      if (option.tagName === 'OPTION') {
                        // If it's the placeholder (first option with empty value), don't allow toggling it
                        if (option.value === "" && option.disabled) return;

                        option.selected = !option.selected;

                        // Automatically deselect the placeholder if another option is selected
                        const firstOpt = this.options[0];
                        if (firstOpt && firstOpt.value === "") {
                          firstOpt.selected = false;
                        }

                        // Trigger change event manually
                        const event = new Event('change', { bubbles: true });
                        this.dispatchEvent(event);
                      }
                      return false;
                    });
                  }

                  const restriction = String(el.allowedValue || '')
                    .trim()
                    .toLowerCase();

                  const transform = String(el.textTransform || '')
                    .trim()
                    .toLowerCase();

                  const applyValidation = function () {
                    let value = this.value;

                    // LETTERS ONLY
                    if (
                      restriction === 'letters' ||
                      restriction === 'letter'
                    ) {
                      value = value.replace(/[^a-zA-Z ]/g, '');
                    }

                    // NUMBERS ONLY
                    else if (
                      restriction === 'numbers' ||
                      restriction === 'number' ||
                      restriction === 'numeric'
                    ) {
                      value = value.replace(/[^0-9]/g, '');
                    }

                    // ALPHANUMERIC ONLY
                    else if (
                      restriction === 'alphanumeric' ||
                      restriction === 'alpha-numeric'
                    ) {
                      value = value.replace(/[^a-zA-Z0-9 ]/g, '');
                    }

                    // TEXT TRANSFORM
                    if (transform === 'uppercase') {
                      value = value.toUpperCase();
                    }

                    else if (transform === 'lowercase') {
                      value = value.toLowerCase();
                    }

                    else if (transform === 'capitalize') {
                      value = value.replace(/\b\w/g, c => c.toUpperCase());
                    }

                    if (this.value !== value) {
                      this.value = value;
                    }
                  };

                  input.addEventListener('input', applyValidation);
                  input.addEventListener('keyup', applyValidation);
                  input.addEventListener('change', applyValidation);

                  applyValidation.call(input);

                }, 0);

                if (el.showCharacterCounter && el.maxCharacter) {
                  setTimeout(() => {
                    const input = document.getElementById(elId);
                    const counter = document.getElementById(elId + '-counter');
                    if (input && counter) {
                      const update = () => { counter.textContent = input.value.length + ' / ' + el.maxCharacter; };
                      input.addEventListener('input', update);
                      update();
                    }
                  }, 0);
                }
              } catch (e) {}
            });
            setElement.appendChild(groupElement);
          });
          container.appendChild(setElement);
        } catch (e) {}
      });

      container.addEventListener('input', () => applyConditionalLogic(container));
      container.addEventListener('change', () => applyConditionalLogic(container));
      applyConditionalLogic(container);

      interceptAddToCart();
      initFlatpickr();
    }

    function initFlatpickr() {
        const inputs = document.querySelectorAll('.se-datetime-input');
        if (inputs.length === 0) return;

        if (!window.flatpickr) {
            const link = document.createElement('link');
            link.rel = 'stylesheet';
            link.href = 'https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css';
            document.head.appendChild(link);

            const script = document.createElement('script');
            script.src = 'https://cdn.jsdelivr.net/npm/flatpickr';
            script.onload = () => {
                document.querySelectorAll('.se-datetime-input').forEach(input => setupFlatpickrInstance(input));
            };
            document.head.appendChild(script);
        } else {
            inputs.forEach(input => setupFlatpickrInstance(input));
        }
    }

    function setupFlatpickrInstance(input) {
        if (input._flatpickr) return;
        
        const elIdAttr = input.id.replace('-start', '').replace('-end', '');
        // The elId in renderOptionSets is 'se-opt-' + el.id
        const elementId = elIdAttr.replace('se-opt-', '');
        
        let elConfig = null;
        if (window.__seOptionSets) {
            window.__seOptionSets.forEach(set => {
                const groups = typeof set.groups === 'string' ? JSON.parse(set.groups) : set.groups;
                groups.forEach(group => {
                    group.elements.forEach(el => {
                        if (el.id.toString() === elementId) elConfig = el;
                    });
                });
            });
        }

        if (!elConfig) {
            console.warn("[SE] Could not find config for element:", elementId);
            return;
        }

        const isTime = elConfig.dateFormat === 'time';
        const isDateTime = elConfig.dateFormat === 'date_time';
        const displayFormat = elConfig.dateDisplayFormat || 'Y-m-d';

        let flatpickrFormat = displayFormat;
        if (isTime) flatpickrFormat = 'h:i K';
        else if (isDateTime) flatpickrFormat = displayFormat + ' h:i K';

        if (typeof flatpickr !== 'function') {
            console.error("[SE] Flatpickr function not found.");
            return;
        }

        flatpickr(input, {
            enableTime: isTime || isDateTime,
            noCalendar: isTime,
            dateFormat: flatpickrFormat,
            time_24hr: false,
            allowInput: true,
            // Removing static: true to prevent cutting by parent containers
            onReady: (selectedDates, dateStr, instance) => {
                input.type = 'text';
            }
        });
    }

    function interceptAddToCart() {
      if (window.__seAddonPatched) return;
      window.__seAddonPatched = true;
      const originalFetch = window.fetch;
      window.fetch = function(...args) {
        const url = typeof args[0] === 'string' ? args[0] : args[0]?.url || '';
        const options = args[1] || {};
        if (url.includes('/cart/add') && (options.method || 'POST').toUpperCase() === 'POST' && options.body) {
          try {
            const addonVariants = getActiveAddons();
            const widgetProps = getWidgetProperties();
            if (addonVariants.length > 0) {
              const addonJson = JSON.stringify(addonVariants.map(v => ({ gid: v.gid, price: v.price })));
              
              if (options.body instanceof FormData) {
                const formData = options.body;
                // For FormData, we can't easily transform to items[] without knowing all fields.
                // So we just keep the property injection for now, but ensure it's on the main item.
                formData.append('properties[_addons]', addonJson);
                for (const [key, val] of Object.entries(widgetProps)) {
                  if (!formData.has('properties[' + key + ']')) {
                    formData.append('properties[' + key + ']', val);
                  }
                }
              } else if (typeof options.body === 'string') {
                const bodyJson = JSON.parse(options.body);
                const items = [];
                
                // 1. Prepare the main product(s)
                const originalItems = bodyJson.items || (bodyJson.id ? [bodyJson] : []);
                originalItems.forEach(item => {
                  item.properties = Object.assign({}, item.properties || {}, { _addons: addonJson }, widgetProps);
                  items.push(item);
                });
                
                // 2. Add each addon as a separate line item
                addonVariants.forEach(v => {
                  if (v.gid) {
                    const variantId = v.gid.split('/').pop();
                    items.push({
                      id: variantId,
                      quantity: v.quantity || 1,
                      properties: { _se_addon: 'true', _se_parent: originalItems[0]?.id || 'main' }
                    });
                  }
                });
                
                if (items.length > 0) {
                  const newBody = { items: items };
                  options.body = JSON.stringify(newBody);
                }
              }
            } else if (Object.keys(widgetProps).length > 0) {
              // Handle case with properties but no addons
              if (options.body instanceof FormData) {
                for (const [key, val] of Object.entries(widgetProps)) {
                  if (!options.body.has('properties[' + key + ']')) {
                    options.body.append('properties[' + key + ']', val);
                  }
                }
              } else if (typeof options.body === 'string') {
                const bodyJson = JSON.parse(options.body);
                if (bodyJson.id) {
                  bodyJson.properties = Object.assign({}, bodyJson.properties || {}, widgetProps);
                } else if (bodyJson.items) {
                  bodyJson.items.forEach(i => i.properties = Object.assign({}, i.properties || {}, widgetProps));
                }
                options.body = JSON.stringify(bodyJson);
              }
            }
          } catch (e) {
            console.error("[SE] Cart intercept error:", e);
          }
        }
        return originalFetch.apply(this, args);
      };
    }
    startInitialization();
  })();
</script>

