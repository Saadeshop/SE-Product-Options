                      else { dropdown.classList.add('se-cp-visible'); trigger.classList.add('se-cp-open'); overlay.style.display = 'block'; }
                    });
                    overlay.addEventListener('click', function() {
                      dropdown.classList.remove('se-cp-visible'); trigger.classList.remove('se-cp-open'); overlay.style.display = 'none';
                    });
                    
                    // Saturation drag
                    const onSatMove = (e) => {
                      const rect = satEl.getBoundingClientRect();
                      sat = Math.max(0, Math.min(100, ((e.clientX - rect.left) / rect.width) * 100));
                      bri = Math.max(0, Math.min(100, (1 - (e.clientY - rect.top) / rect.height) * 100));
                      updateUI();
                    };
                    satEl.addEventListener('mousedown', function(e) {
                      onSatMove(e);
                      const onMove = (ev) => onSatMove(ev);
                      const onUp = () => { document.removeEventListener('mousemove', onMove); document.removeEventListener('mouseup', onUp); };
                      document.addEventListener('mousemove', onMove);
                      document.addEventListener('mouseup', onUp);
                    });
                    
                    // Hue drag
                    const onHueMove = (e) => {
                      const rect = hueBar.getBoundingClientRect();
                      hue = Math.max(0, Math.min(360, ((e.clientX - rect.left) / rect.width) * 360));
                      updateUI();
                    };
                    hueBar.addEventListener('mousedown', function(e) {
                      onHueMove(e);
                      const onMove = (ev) => onHueMove(ev);
                      const onUp = () => { document.removeEventListener('mousemove', onMove); document.removeEventListener('mouseup', onUp); };
                      document.addEventListener('mousemove', onMove);
                      document.addEventListener('mouseup', onUp);
                    });
                    
                    // Hex input
                    hexInput.addEventListener('input', function() {
                      let val = hexInput.value.trim();
                      if (!val.startsWith('#')) val = '#' + val;
                      if (/^#[0-9a-fA-F]{6}$/.test(val)) {
                        const parsed = parseHex(val);
                        hue = parsed.h; sat = parsed.s; bri = parsed.v;
                        updateUI();
                      }
                    });
                    
                    // Preset clicks
                    container.querySelectorAll('.se-cp-preset').forEach(function(p) {
                      p.addEventListener('click', function() {
                        const parsed = parseHex(p.dataset.color);
                        hue = parsed.h; sat = parsed.s; bri = parsed.v;
                        updateUI();
                      });
                    });
                    
                    updateUI();
                  }, 0);
                } else if (el.type === 'switch') {
                  const propertyName = el.name || el.label;
                  const isChecked = el.selectedByDefault ? 'checked' : '';
                  html += `
                    <div class="se-switch-container">
                      <label class="se-switch">
                        <input type="checkbox" id="${elId}" name="properties[${propertyName}]" value="Yes" ${isChecked}>
                        <span class="se-slider"></span>
                      </label>
                      <label for="${elId}" class="se-switch-label-text">${el.placeholder || ""}</label>
                    </div>
                  `;
                  const showBottomHelp = (!el.helpTextPosition || el.helpTextPosition === 'below') && el.helpText;
                  if (showBottomHelp) {
                    html += '<div class="se-bottom-row" style="margin-top: 4px;">' + helpTextHtml + '</div>';
                  }
                } else if (el.type === 'font-picker') {
                  const FONTS = [
                    "Arial", "Helvetica", "Georgia", "Times New Roman", "Courier New", "Verdana", 
